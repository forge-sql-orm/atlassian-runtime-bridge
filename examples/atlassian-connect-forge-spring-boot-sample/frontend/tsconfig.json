{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react",
    "lib": ["ES2020", "DOM"],
    "rootDir": "src/main/resources/javascript",
    "baseUrl": "..",
    "paths": {
      "app-transport": ["src/main/resources/javascript/connect.ts"]
    }
  },
  "include": ["src/main/resources/javascript/**/*.ts", "src/main/resources/javascript/**/*.d.ts"]
}
